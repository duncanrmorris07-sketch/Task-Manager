{
  "name": "hausmeister-task-manager",
  "version": "1.0.0",
  "description": "Job management app for hausmeister with Google Calendar integration",
  "main": "electron-main.js",
  "homepage": "./",
  "author": "Hausmeister",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "react-scripts build",
    "dev": "concurrently \"npm run react-dev\" \"npm run electron-dev\"",
    "react-dev": "BROWSER=none react-scripts start",
    "electron-dev": "sleep 3 && electron . --enable-logging",
    "eject": "react-scripts eject"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sqlite3": "^5.1.6",
    "google-auth-library": "^8.8.0",
    "googleapis": "^118.0.0",
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.0.0",
    "react-scripts": "5.0.1",
    "concurrently": "^8.2.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.9.0",
    "web-vitals": "^2.1.4"
  },
  "build": {
    "appId": "com.hausmeister.taskmanager",
    "productName": "Hausmeister Task Manager",
    "files": [
      "build/**/*",
      "electron-main.js",
      "preload.js",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "mac": {
      "category": "public.app-category.productivity"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
